{
  "lexicon": 1,
  "id": "space.chartid.eventChart",
  "description": "Chart for a moment in time — eclipse, IPO, launch, ingress, mundane event. eventDatetime is required. No subject DID — this records the moment, not a person.",
  "defs": {
    "record": {
      "type": "record",
      "key": "tid",
      "description": "Astrological chart for a discrete event or moment. Used for mundane astrology, financial events, eclipses, and any time-stamped happening worth charting.",
      "required": ["schemaVersion", "traditions", "eventDatetime", "createdAt"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0.0",
          "description": "Schema version. Breaking changes bump to 2.0.0 in a new lexicon file."
        },
        "traditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Astrological traditions represented, e.g. ['western', 'jyotish']."
        },
        "eventDatetime": {
          "type": "string",
          "format": "datetime",
          "description": "Date and time of the event (ISO 8601, UTC preferred). Required."
        },
        "eventName": {
          "type": "string",
          "maxLength": 256,
          "description": "Short name or label for the event, e.g. 'Total Solar Eclipse — April 2024'."
        },
        "eventType": {
          "type": "string",
          "knownValues": ["eclipse", "ingress", "opposition", "launch", "ipo", "election", "mundane", "other"],
          "description": "Classification of the event type."
        },
        "place": {
          "type": "object",
          "description": "Location relevant to the event (e.g., where a company was founded, where an eclipse is total).",
          "properties": {
            "placeName": { "type": "string", "maxLength": 256 },
            "coordinate": {
              "type": "object",
              "properties": {
                "latitude": { "type": "string" },
                "longitude": { "type": "string" }
              }
            },
            "timezone": { "type": "string" }
          }
        },
        "description": {
          "type": "string",
          "maxLength": 1024,
          "description": "Optional longer description of the event and its astrological significance."
        },
        "western": {
          "type": "object",
          "description": "Western tropical astrological data. See space.chartid.defs#westernData.",
          "properties": {
            "houseSystem": { "type": "string" },
            "ascendant": { "type": "string" },
            "midheaven": { "type": "string" },
            "planets": { "type": "array", "items": { "type": "unknown" } },
            "houseCusps": { "type": "array", "items": { "type": "unknown" } },
            "extensions": { "type": "unknown" }
          }
        },
        "jyotish": {
          "type": "object",
          "description": "Jyotish astrological data. See space.chartid.defs#jyotishData.",
          "properties": {
            "ayanamsa": { "type": "string" },
            "ayanamsaDegrees": { "type": "string" },
            "houseSystem": { "type": "string" },
            "ascendant": { "type": "string" },
            "planets": { "type": "array", "items": { "type": "unknown" } },
            "houseCusps": { "type": "array", "items": { "type": "unknown" } },
            "extensions": { "type": "unknown" }
          }
        },
        "extensions": {
          "type": "unknown",
          "description": "Top-level extension point for fields not yet in spec."
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "Timestamp when this record was created (ISO 8601)."
        }
      }
    }
  }
}
